.env
.streamlit/secrets.toml
__pycache__/
*.pyc
.DS_Store
.venv/
venv/
data/cache/tmp*
data/cache/*.jsonl
data/cache/extraction_cache.json

# Derived, mutable runtime state.  The only permanent state file is
# data/canonical/resume_package_canonical.json.  Everything under
# data/output/ is regenerated from the canonical and must not be tracked.
data/output/rerun_queue.json
data/output/problem_queue.json
data/output/batch_state.json
data/output/latest_batch_result.json
data/output/run_history.json
data/output/gemini_raw_runs.json
data/output/unresolved_models.json
data/output/vehicle_candidates_raw.json
data/output/vehicle_variants_partial.json
data/output/vehicle_variants_verified.json
data/output/vehicle_conflicts.json
data/output/vehicle_sources.json

# Timestamped canonical backups (kept locally only).
data/canonical/backups/

# The canonical resume package is uploaded by the user out-of-band; it is
# environment-state, never source-controlled.  Likewise the rolling
# "previous" backup is a derived artifact of canonical writes.
data/canonical/resume_package_canonical.json
data/canonical/resume_package_backup_previous.json
